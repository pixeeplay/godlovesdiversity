generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ───────────────────────────────────────────────
// AUTH (NextAuth Prisma adapter)
// ───────────────────────────────────────────────
model User {
  id             String    @id @default(cuid())
  email          String    @unique
  name           String?
  image          String?
  passwordHash   String?
  role           Role      @default(VIEWER)
  emailVerified  DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  accounts       Account[]
  sessions       Session[]
  photosUploaded Photo[]   @relation("uploader")
  photosReviewed Photo[]   @relation("reviewer")
  articles       Article[]
  auditLogs      AuditLog[]

  // V2 — Forum
  forumThreads   ForumThread[] @relation("threadAuthor")
  forumPosts     ForumPost[]   @relation("postAuthor")
  // V2 — Témoignages vidéo
  testimoniesUploaded VideoTestimony[]
  // V2 — Parrainage
  referralCodes  ReferralCode[]
  // V2.1 — Boutique avancée
  reviews        ProductReview[]
  wishlist       Wishlist[]
  loyaltyAccount LoyaltyAccount?
  // V2 — Venues (établissements LGBT)
  ownedVenues    Venue[]

  // V2.5 — Sync feed Facebook personnel (cookies session pour scraping headless)
  fbSessionCookies String? @db.Text
  fbLastSyncedAt   DateTime?

  // V3 — Profil enrichi back-office user
  bio                  String?  @db.Text
  publicName           String?  // pseudo affiché publiquement (différent de name)
  identity             String?  // libre : "gay", "lesbienne", "trans", "non-binaire", "queer", "questionnement"…
  traditions           String[] @default([])  // ["catholique", "musulman", …]
  cityProfile          String?
  ghostMode            Boolean  @default(false)
  notifyDigest         Boolean  @default(true)
  notifyEvents         Boolean  @default(true)
  notifyPeerHelp       Boolean  @default(true)
  notifyMentor         Boolean  @default(true)
  notifyShop           Boolean  @default(true)
  // V4 — Dashboard perso visuel
  bannerUrl       String?   // bannière personnelle uploadée ou générée IA
  bannerPrompt    String?   @db.Text  // prompt utilisé pour générer
  dashboardTheme  String?   @default("fuchsia")  // "fuchsia" | "violet" | "cyan" | "rose" | "amber" | "emerald"
  favoriteColor   String?   @default("#d61b80")

  bookmarks         Bookmark[]
  journalEntries    JournalEntry[]
  futureLetters     FutureLetter[]
  aiConversations   AIConversation[]
  activityLogs      UserActivityLog[]

  // V5 — GLD Connect (réseau social 3-en-1)
  connectProfile    ConnectProfile?
  swipesGiven       ConnectSwipe[]      @relation("swipeFrom")
  swipesReceived    ConnectSwipe[]      @relation("swipeTo")
  connectionsFrom   ConnectConnection[] @relation("connFrom")
  connectionsTo     ConnectConnection[] @relation("connTo")
  connectPosts      ConnectPost[]
  connectReactions  ConnectReaction[]
  conversations1    ConnectConversation[] @relation("convA")
  conversations2    ConnectConversation[] @relation("convB")
  connectMessages   ConnectMessage[]
  reportsFiled      ConnectReport[]     @relation("reporterRel")
  reportsAgainst    ConnectReport[]     @relation("reportedRel")
  blocksGiven       ConnectBlock[]      @relation("blockerRel")
  blocksReceived    ConnectBlock[]      @relation("blockedRel")
  premiumSub        ConnectPremium?
}

/// Bookmark générique (témoignages, lieux, posts, produits, events).
model Bookmark {
  id           String   @id @default(cuid())
  userId       String
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  resourceType String   // "testimony" | "venue" | "post" | "product" | "event"
  resourceId   String
  note         String?
  createdAt    DateTime @default(now())
  @@unique([userId, resourceType, resourceId])
  @@index([userId, resourceType])
}

/// Journal intime — strictement privé, jamais publié.
model JournalEntry {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  title     String?
  content   String   @db.Text
  encrypted Boolean  @default(false)  // chiffré côté client si user le veut
  mood      String?  // "joyeux" | "triste" | "anxieux" | "fier" | "espoir" | "colère"
  tags      String[] @default([])
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  @@index([userId, createdAt])
}

/// Lettre programmée à soi-même — délivrée à une date future par email.
model FutureLetter {
  id           String   @id @default(cuid())
  userId       String
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  subject      String?
  content      String   @db.Text
  deliveryDate DateTime
  delivered    Boolean  @default(false)
  deliveredAt  DateTime?
  createdAt    DateTime @default(now())
  @@index([deliveryDate, delivered])
}

/// Conversations IA sauvegardées (Voice Coach, Verset, Juridique).
model AIConversation {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  tool      String   // "voice-coach" | "legal" | "verse" | "ask-gld"
  title     String?
  messages  Json     // [{role: "user"|"ai", content: "..."}]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  @@index([userId, tool, createdAt])
}

/// Log d'activité user pour timeline + feed perso.
model UserActivityLog {
  id           String   @id @default(cuid())
  userId       String
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  action       String   // "post_created" | "comment_added" | "support_given" | "bookmark_added" | "badge_earned" | …
  resourceType String?
  resourceId   String?
  metadata     Json?
  createdAt    DateTime @default(now())
  @@index([userId, createdAt])
}

enum Role {
  ADMIN
  EDITOR
  MODERATOR
  VIEWER
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ───────────────────────────────────────────────
// PHOTOS UGC (cœur du projet)
// ───────────────────────────────────────────────
model Photo {
  id            String        @id @default(cuid())
  storageKey    String        // chemin MinIO/S3
  thumbnailKey  String?
  caption       String?
  authorName    String?       // nom affiché (peut être anonyme)
  authorEmail   String?
  locale        String        @default("fr")
  status        PhotoStatus   @default(PENDING)
  rejectionReason String?

  // Géolocalisation
  latitude      Float?
  longitude     Float?
  city          String?
  country       String?
  placeName     String?       // nom du lieu de culte
  placeType     PlaceType?

  // Modération
  uploadedById  String?
  uploadedBy    User?         @relation("uploader", fields: [uploadedById], references: [id])
  reviewedById  String?
  reviewedBy    User?         @relation("reviewer", fields: [reviewedById], references: [id])
  reviewedAt    DateTime?
  aiModerationScore Float?
  aiModerationFlags Json?

  // Engagement
  likes         Int           @default(0)
  source        Source        @default(WEB)
  ipHash        String?

  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  @@index([status, createdAt])
  @@index([country])
  @@index([placeType])
}

enum PhotoStatus {
  PENDING
  APPROVED
  REJECTED
  FLAGGED
}

enum PlaceType {
  CHURCH
  MOSQUE
  SYNAGOGUE
  TEMPLE
  PUBLIC_SPACE
  OTHER
}

enum Source {
  WEB
  IOS
  ANDROID
  IMPORT
}

// ───────────────────────────────────────────────
// CONTENU (CMS)
// ───────────────────────────────────────────────
model Page {
  id        String   @id @default(cuid())
  slug      String   @unique
  locale    String   @default("fr")
  title     String
  content   Json
  published Boolean  @default(true)
  updatedAt DateTime @updatedAt
  createdAt DateTime @default(now())

  @@unique([slug, locale])
}

model Article {
  id          String   @id @default(cuid())
  slug        String
  locale      String   @default("fr")
  title       String
  excerpt     String?
  content     Json
  coverImage  String?
  coverVideo  String?
  tags        String[]
  published   Boolean  @default(false)
  publishedAt DateTime?
  authorId    String?
  author      User?    @relation(fields: [authorId], references: [id])
  updatedAt   DateTime @updatedAt
  createdAt   DateTime @default(now())

  @@unique([slug, locale])
  @@index([published, publishedAt])
}

/// Vidéo YouTube embed pour le carousel vidéos de la home.
model YoutubeVideo {
  id           String   @id @default(cuid())
  videoId      String   // ex: "dQw4w9WgXcQ" (portion après v=)
  title        String
  description  String?
  thumbnailUrl String?  // URL d'une vignette personnalisée (sinon fallback img.youtube.com)
  order        Int      @default(0)
  published    Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([published, order])
}

/// Bannière du carrousel hero. 5 par défaut, ordre customizable.
model Banner {
  id          String   @id @default(cuid())
  locale      String   @default("fr")
  eyebrow     String?
  title       String
  subtitle    String?
  mediaUrl    String?
  mediaType   String?  // 'image' | 'video'
  cta1Text    String?
  cta1Url     String?
  cta2Text    String?
  cta2Url     String?
  accentColor String?
  order       Int      @default(0)
  published   Boolean  @default(true)

  // Génération IA & événement
  aiPrompt        String?  @db.Text  // Prompt utilisé pour générer la bannière (Imagen / Veo)
  aiModel         String?            // "imagen-3" | "veo" | "manual"
  presetSlug      String?            // "pride" | "noel" | "halloween" | "valentin" | "custom"

  // Calendrier d'activation (optionnel — sinon toujours visible)
  activeFrom      DateTime?
  activeUntil     DateTime?
  /// Slug d'un Theme lié — si le theme est actif, cette banner aussi (override calendrier)
  linkedThemeSlug String?

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([locale, order])
  @@index([activeFrom, activeUntil])
}

/// Item du menu de navigation. Supporte les sous-menus via parentId.
model MenuItem {
  id          String     @id @default(cuid())
  locale      String     @default("fr")
  label       String
  href        String     // ex: /message, /participer, https://...
  external    Boolean    @default(false)
  parentId    String?
  parent      MenuItem?  @relation("MenuChildren", fields: [parentId], references: [id], onDelete: Cascade)
  children    MenuItem[] @relation("MenuChildren")
  order       Int        @default(0)
  published   Boolean    @default(true)
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  @@index([locale, parentId, order])
}

/// Section riche d'une page publique (argumentaire, message, à-propos…).
/// Chaque page est composée de plusieurs Sections empilées verticalement.
/// Une section peut avoir une image OU une vidéo OU juste du texte.
model Section {
  id          String   @id @default(cuid())
  pageSlug    String   // 'argumentaire' | 'message' | 'a-propos' | autre
  locale      String   @default("fr")
  title       String?
  subtitle    String?
  body        String?  @db.Text
  mediaUrl    String?
  mediaType   String?  // 'image' | 'video'
  layout      String   @default("text-image") // text-image | image-text | full-image | text-only | quote | banner
  accentColor String?  // hex couleur pour le titre/accent
  ctaText     String?
  ctaUrl      String?
  order       Int      @default(0)
  published   Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([pageSlug, locale, order])
}

model Poster {
  id           String   @id @default(cuid())
  title        String
  description  String?
  format       String   // ex: "A1", "A2", "A3", "Story", "Carré"
  fileKey      String   // chemin du PDF dans MinIO
  thumbnailKey String?  // image preview
  size         String?  // ex: "594×841 mm"
  order        Int      @default(0)
  published    Boolean  @default(true)
  downloads    Int      @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([published, order])
}

// ───────────────────────────────────────────────
// NEWSLETTER
// ───────────────────────────────────────────────
model NewsletterSubscriber {
  id           String              @id @default(cuid())
  email        String              @unique
  locale       String              @default("fr")
  status       SubscriberStatus    @default(PENDING)
  confirmToken String?             @unique
  unsubToken   String              @unique @default(cuid())
  source       String?
  createdAt    DateTime            @default(now())
  confirmedAt  DateTime?
}

enum SubscriberStatus {
  PENDING
  ACTIVE
  UNSUBSCRIBED
  BOUNCED
}

model NewsletterCampaign {
  id              String   @id @default(cuid())
  subject         String
  htmlContent     String   @db.Text
  textContent     String?  @db.Text
  status          CampaignStatus @default(DRAFT)
  scheduledAt     DateTime?
  sentAt          DateTime?
  recipients      Int      @default(0)  // total destinataires ciblés (snapshot au moment de l'envoi)
  recipientsCount Int      @default(0)  // alias explicite — même valeur que recipients (kept for clarity)
  sentCount       Int      @default(0)  // emails effectivement envoyés (peut < recipientsCount si erreurs)
  failedCount     Int      @default(0)  // emails en échec
  opens           Int      @default(0)
  clicks          Int      @default(0)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

enum CampaignStatus {
  DRAFT
  SCHEDULED
  SENDING
  SENT
  FAILED
}

// ───────────────────────────────────────────────
// CALENDRIER SOCIAL
// ───────────────────────────────────────────────
model ScheduledPost {
  id           String         @id @default(cuid())
  title        String?
  content      String         @db.Text
  mediaKeys    String[]
  channels     String[]       // ['INSTAGRAM','X','LINKEDIN','TIKTOK','FACEBOOK']
  scheduledAt  DateTime
  status       PostStatus     @default(PENDING)
  publishedAt  DateTime?
  results      Json?          // logs par canal
  createdById  String?
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt

  @@index([scheduledAt, status])
}

enum PostStatus {
  PENDING
  PUBLISHED
  FAILED
  CANCELLED
}

// ───────────────────────────────────────────────
// V2 — FORUM MEMBRES
// ───────────────────────────────────────────────

model ForumCategory {
  id          String        @id @default(cuid())
  slug        String        @unique
  name        String
  description String?
  color       String?       // hex pour badge
  order       Int           @default(0)
  threads     ForumThread[]
  createdAt   DateTime      @default(now())
}

model ForumThread {
  id          String        @id @default(cuid())
  slug        String        @unique
  title       String
  categoryId  String
  category    ForumCategory @relation(fields: [categoryId], references: [id])
  authorId    String?
  author      User?         @relation("threadAuthor", fields: [authorId], references: [id])
  pinned      Boolean       @default(false)
  locked      Boolean       @default(false)
  status      String        @default("active") // active | hidden | deleted
  postsCount  Int           @default(0)
  viewsCount  Int           @default(0)
  lastReplyAt DateTime?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  posts       ForumPost[]

  @@index([categoryId, lastReplyAt])
  @@index([status, createdAt])
}

model ForumPost {
  id        String      @id @default(cuid())
  threadId  String
  thread    ForumThread @relation(fields: [threadId], references: [id], onDelete: Cascade)
  authorId  String?
  author    User?       @relation("postAuthor", fields: [authorId], references: [id])
  content   String      @db.Text
  status    String      @default("active") // active | hidden | flagged | deleted
  likes     Int         @default(0)
  parentId  String?     // pour les réponses imbriquées
  parent    ForumPost?  @relation("PostReplies", fields: [parentId], references: [id])
  replies   ForumPost[] @relation("PostReplies")
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt

  @@index([threadId, createdAt])
  @@index([authorId, createdAt])
}

// ───────────────────────────────────────────────
// V2 — TÉMOIGNAGES VIDÉO
// ───────────────────────────────────────────────

model VideoTestimony {
  id            String   @id @default(cuid())
  authorName    String?
  authorEmail   String?
  videoUrl      String   // URL MinIO ou YouTube
  thumbnailUrl  String?
  duration      Int?     // secondes
  locale        String   @default("fr")
  title         String?
  transcription String?  @db.Text
  subtitlesFr   String?  @db.Text  // VTT format
  subtitlesEn   String?  @db.Text
  subtitlesEs   String?  @db.Text
  subtitlesPt   String?  @db.Text
  status        String   @default("pending") // pending | approved | rejected
  uploadedById  String?
  uploadedBy    User?    @relation(fields: [uploadedById], references: [id])
  rejectionReason String?
  views         Int      @default(0)
  likes         Int      @default(0)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([status, createdAt])
}

// ───────────────────────────────────────────────
// V2 — PARRAINAGE
// ───────────────────────────────────────────────

model ReferralCode {
  id          String     @id @default(cuid())
  code        String     @unique
  ownerId     String?
  owner       User?      @relation(fields: [ownerId], references: [id])
  uses        Int        @default(0)
  rewardKind  String     @default("discount") // discount | product | credit
  rewardValue Int        @default(0) // centimes ou points
  active      Boolean    @default(true)
  createdAt   DateTime   @default(now())
  redemptions Referral[]
}

model Referral {
  id            String       @id @default(cuid())
  codeId        String
  code          ReferralCode @relation(fields: [codeId], references: [id])
  referredEmail String
  status        String       @default("pending") // pending | converted | expired
  convertedAt   DateTime?
  rewardGivenAt DateTime?
  createdAt     DateTime     @default(now())

  @@index([codeId, status])
}

// ───────────────────────────────────────────────
// V2.1 — BOUTIQUE AVANCÉE
// ───────────────────────────────────────────────

model Coupon {
  id              String    @id @default(cuid())
  code            String    @unique
  discountKind    String    @default("percent") // percent | fixed
  discountValue   Int       // % ou centimes
  minOrderCents   Int?
  maxUses         Int?
  uses            Int       @default(0)
  validFrom       DateTime?
  validUntil      DateTime?
  productCategory String?   // restriction par catégorie produit
  active          Boolean   @default(true)
  createdAt       DateTime  @default(now())
  createdBy       String?

  @@index([active, validUntil])
}

model ProductReview {
  id        String   @id @default(cuid())
  productId String
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  authorId  String?
  author    User?    @relation(fields: [authorId], references: [id])
  rating    Int      // 1-5
  title     String?
  content   String?  @db.Text
  photos    String[] // URLs photos clients
  verified  Boolean  @default(false) // true = a réellement acheté
  status    String   @default("pending") // pending | approved | rejected
  createdAt DateTime @default(now())

  @@index([productId, status])
}

model Wishlist {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  productId String
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([userId, productId])
}

model StockAlert {
  id          String   @id @default(cuid())
  email       String
  productId   String
  variantOpts Json?    // pour alerter sur un variant spécifique
  notifiedAt  DateTime?
  createdAt   DateTime @default(now())

  @@index([productId, notifiedAt])
}

model LoyaltyAccount {
  id        String   @id @default(cuid())
  userId    String   @unique
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  points    Int      @default(0)
  tier      String   @default("bronze") // bronze | silver | gold
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  ledger    LoyaltyLedger[]
}

model LoyaltyLedger {
  id          String         @id @default(cuid())
  accountId   String
  account     LoyaltyAccount @relation(fields: [accountId], references: [id], onDelete: Cascade)
  delta       Int            // +X (gain) ou -X (dépense)
  reason      String         // "order:XYZ" | "referral" | "redeem"
  metadata    Json?
  createdAt   DateTime       @default(now())

  @@index([accountId, createdAt])
}

/// Log de tous les messages échangés via le bot Telegram (in/out).
/// Permet l'historique du chat live dans /admin/integrations/telegram.
model TelegramMessage {
  id            String   @id @default(cuid())
  direction     String   // 'in' (visiteur → bot) | 'out' (bot → chat)
  chatId        String   // ID du chat Telegram (privé ou groupe)
  userId        String?  // user_id du sender (null pour les outbound non liés à un user)
  username      String?  // @username Telegram
  firstName     String?
  text          String?  @db.Text
  command       String?  // commande extraite (/help, /stats, etc.) ou intent IA détectée
  aiInterpreted Boolean  @default(false) // true si on a appelé l'AI router pour interpréter
  imageUrl      String?  // URL de la photo si message photo
  callbackData  String?  // payload du callback si bouton inline cliqué
  status        String   @default("delivered") // delivered | failed | ignored
  errorMessage  String?  @db.Text
  raw           Json?    // payload brut Telegram pour debug
  createdAt     DateTime @default(now())

  @@index([chatId, createdAt])
  @@index([direction, createdAt])
}

// ───────────────────────────────────────────────
// V2 — VENUES LGBT-FRIENDLY (annuaire mondial)
// ───────────────────────────────────────────────

enum VenueType {
  RESTAURANT
  BAR
  CAFE
  CLUB
  HOTEL
  SHOP
  CULTURAL          // musée, galerie, théâtre
  CHURCH            // église
  TEMPLE            // temple, synagogue, mosquée, autre lieu de culte
  COMMUNITY_CENTER  // centre LGBT
  HEALTH            // santé, planning familial
  ASSOCIATION
  OTHER
}

enum VenueRating {
  RAINBOW           // 100 % LGBT — événements, drapeau, équipe
  FRIENDLY          // ouvertement accueillant
  NEUTRAL           // pas hostile, mais pas spécifiquement engagé
  CAUTION           // remontées négatives — à approfondir
}

model Venue {
  id            String      @id @default(cuid())
  slug          String      @unique
  type          VenueType
  rating        VenueRating @default(FRIENDLY)
  name          String
  description   String?     @db.Text
  shortDescription String?  // pour les cards

  // Adresse
  address       String?
  city          String?
  postalCode    String?
  country       String?     // code ISO-2
  region        String?     // état/région
  lat           Float?
  lng           Float?

  // Contact
  phone         String?
  email         String?
  website       String?
  bookingUrl    String?

  // Médias
  coverImage    String?
  photos        String[]    @default([])
  logo          String?

  // Horaires + tags
  openingHours  Json?       // { mon: "10:00-22:00", tue: "...", ... }
  tags          String[]    @default([]) // ex ["happy-hour", "drag-show", "brunch"]

  // Réseaux sociaux
  instagram     String?
  facebook      String?

  // Synchro Facebook events (pull events depuis la Page FB du venue)
  facebookPageId      String?  // ID numérique ou username de la Page FB
  facebookPageToken   String?  @db.Text  // Page Access Token long-lived (chiffré idéalement)
  autoPublishFbEvents Boolean  @default(false) // true = published direct, false = brouillon (published=false)
  fbSyncedAt          DateTime?  // dernière synchro réussie

  // Owner pour gérer ses events + coupons depuis /admin
  ownerId       String?
  owner         User?       @relation(fields: [ownerId], references: [id])
  ownerEmail    String?     // si owner pas inscrit

  // Statut + meta
  verified      Boolean     @default(false)  // vérifié par admin GLD
  published     Boolean     @default(true)
  featured      Boolean     @default(false)
  views         Int         @default(0)

  // Enrichissement IA (Gemini grounded search)
  googlePlaceId         String?     // Place ID Google Maps si trouvé
  enrichedAt            DateTime?   // dernière fois que l'enrichissement a tourné
  enrichmentConfidence  Float?      // 0..1 : 0.9 = source officielle Google Maps, 0.7 = sites multiples cohérents, 0.4 = unique source
  enrichmentSources     Json?       // [{url, title, fields:["phone","hours"]}, ...] — citations Gemini
  enrichmentNotes       String?     @db.Text // résumé textuel des modifs faites par l'IA + warnings

  // Médias enrichis (V2)
  videos                String[]   @default([])  // URLs YouTube/Vimeo trouvées par IA
  upcomingEventsHint    Json?      // [{title, date, source}] events détectés depuis FB/IG sans encore importer
  freshnessScore        Float?     // 0..100, % de complétude de la fiche
  freshnessCheckedAt    DateTime?

  events        Event[]                 // events qui se passent dans ce lieu
  coupons       VenueCoupon[]
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  @@index([type, country, city])
  @@index([rating, published])
  @@index([featured, published])
  @@index([lat, lng])
  @@index([enrichedAt])
}

/// Coupon spécifique à un Venue (ex: -10% au resto Le Refuge sur présentation).
model VenueCoupon {
  id            String   @id @default(cuid())
  venueId       String
  venue         Venue    @relation(fields: [venueId], references: [id], onDelete: Cascade)
  code          String   @unique
  description   String?
  discountKind  String   @default("percent") // percent | fixed | freebie
  discountValue Int      @default(0)
  maxUses       Int?
  uses          Int      @default(0)
  validFrom     DateTime?
  validUntil    DateTime?
  active        Boolean  @default(true)
  createdAt     DateTime @default(now())

  @@index([venueId, active])
}

/// Événement public visible sur /agenda — créé/édité dans /admin/events.
model Event {
  id          String   @id @default(cuid())
  slug        String   @unique
  locale      String   @default("fr")
  title       String
  description String?  @db.Text
  startsAt    DateTime
  endsAt      DateTime?
  location    String?       // ex "Église St-Eustache, Paris"
  city        String?
  country     String?
  address     String?
  lat         Float?
  lng         Float?
  coverImage  String?
  url         String?       // lien externe (billeterie, infos)
  tags        String[]      @default([])
  published   Boolean  @default(true)
  cancelled   Boolean  @default(false)
  // Lien vers un Venue (optionnel — un event peut être hors-venue)
  venueId     String?
  venue       Venue?   @relation(fields: [venueId], references: [id])
  // Source externe (synchro Facebook events, etc.)
  externalSource String?   // "facebook" | "google" | "eventbrite" | null (manual)
  externalId     String?   // ID Facebook/Google/etc. — sert d'idempotence
  externalUrl    String?   // URL d'origine
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([externalSource, externalId])
  @@index([published, startsAt])
  @@index([locale, startsAt])
  @@index([venueId, startsAt])
}

/// Message de chat dans un cercle de prière (group chat planifié).
model PrayerMessage {
  id          String   @id @default(cuid())
  circle      String   // "catholique" | "protestant" | "musulman" | "juif" | "bouddhiste" | "interreligieux"
  authorName  String?
  message     String   @db.Text
  createdAt   DateTime @default(now())

  @@index([circle, createdAt])
}

/// Soumission générique utilisateur — absorbe mentor / hébergement / signalement / meetups / etc.
/// Le champ `kind` discrimine, `data` contient le payload JSON spécifique.
model UserSubmission {
  id          String   @id @default(cuid())
  kind        String   // "mentor-mentee" | "mentor-mentor" | "shelter-host" | "shelter-guest" | "report-place" | "meetup-rsvp" | "marketplace-artisan" | "crowdfunding-project" | "city-coordinator"
  authorEmail String?
  authorName  String?
  city        String?
  country     String?
  data        Json     // payload spécifique au kind
  status      String   @default("pending")  // "pending" | "approved" | "rejected" | "matched"
  notes       String?  @db.Text  // notes admin
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([kind, status])
  @@index([country, city])
}

/// Demande d'aide / message d'entraide LGBT entre utilisateurs (anonyme possible).
/// Pas un chat 1-1 : une demande publique modérée que d'autres peuvent réconforter.
model PeerHelp {
  id          String   @id @default(cuid())
  authorName  String?  // pseudo ou null si anonyme
  authorEmail String?  // pour notification de réponse
  country     String?  // code ISO-2 pour montrer aides locales adaptées
  topic       String   // "coming-out" | "famille" | "abus" | "isolement" | "rejet" | "santé-mentale" | "autre"
  message     String   @db.Text
  urgent      Boolean  @default(false)
  status      String   @default("active") // "active" | "resolved" | "hidden"
  /// Nombre de "je suis là pour toi" reçus
  supportCount Int     @default(0)
  /// Réponses bienveillantes (chiffrées avec auteur si email)
  responses   PeerHelpResponse[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([status, createdAt])
  @@index([topic, status])
}

model PeerHelpResponse {
  id          String   @id @default(cuid())
  peerHelpId  String
  peerHelp    PeerHelp @relation(fields: [peerHelpId], references: [id], onDelete: Cascade)
  authorName  String?  // pseudo ou null
  message     String   @db.Text
  approved    Boolean  @default(false) // modération admin
  createdAt   DateTime @default(now())

  @@index([peerHelpId, approved])
}

/// Thème visuel saisonnier ou esthétique permanent.
/// L'admin peut activer manuellement ou laisser l'auto-activation par date de fête.
model Theme {
  id              String    @id @default(cuid())
  slug            String    @unique // "pride", "noel-2025", "halloween"...
  name            String
  description     String?
  category        String    // "holiday" | "religious" | "national" | "aesthetic" | "seasonal"

  // Couleurs (CSS variables injectées dynamiquement)
  colors          Json      // { primary, secondary, accent, bg, fg, border, ... }
  fonts           Json?     // { display: "...", body: "..." }
  decorations     Json?     // { snow: true, confetti: false, hearts: true, ... }
  customCss       String?   @db.Text

  // Audio d'ambiance (MP3/OGG, optionnel)
  musicUrl        String?   // URL d'une musique en boucle (ex /music/christmas.mp3)
  musicVolume     Float?    @default(0.3) // 0-1
  mood            String?   // "festif", "calme", "mystique", "energique"... (descriptif)

  // Auto-activation
  autoActivate    Boolean   @default(false)
  autoStartMonth  Int?      // 1-12, null si calcul dynamique
  autoStartDay    Int?      // 1-31
  autoEndMonth    Int?
  autoEndDay      Int?
  daysBefore      Int       @default(7)  // active N jours avant
  durationDays    Int       @default(7)  // reste actif N jours
  /// Slug d'une fête dans holiday-calendar pour les dates calculées (Pâques, Pessah, Ramadan, etc.)
  holidaySlug     String?
  geographicScope String?   // "global" | code ISO-2 (FR, US...) ou liste séparée par virgule

  // État
  active          Boolean   @default(false) // activé manuellement maintenant
  priority        Int       @default(0)     // si plusieurs auto-actives, priorité = la plus haute
  preview         String?   // URL screenshot

  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@index([active])
  @@index([category])
  @@index([autoActivate])
}

// ───────────────────────────────────────────────
// PARAMÈTRES & AUDIT
// ───────────────────────────────────────────────
model Setting {
  key   String  @id
  value String  @db.Text
}

/// GLD Soul — entrées du "journal" auto-écrit par l'IA chaque jour.
/// Une voix à la 1ère personne qui synthétise l'activité, l'humeur et les vœux du site.
model SoulEntry {
  id         String   @id @default(cuid())
  date       DateTime @unique  // une entrée par jour (YYYY-MM-DD à minuit UTC)
  mood       String   // joyful | calm | somber | festive | neutral
  moodScore  Float    @default(0.5)  // 0..1, intensité
  body       String   @db.Text       // texte complet de la "voix" du site
  bodyShort  String?  @db.Text       // version courte pour widget home
  stats      Json?    // snapshot des chiffres ce jour-là (users, posts, events, etc.)
  generatedBy String  @default("gemini")  // gemini | manual
  approved   Boolean  @default(true)      // si false, ne pas afficher publiquement
  createdAt  DateTime @default(now())

  @@index([date])
  @@index([mood])
}

/// Manuels auto-générés par IA (user / admin / superadmin), versionnés.
/// Régénérés 2×/jour par cron pour rester à jour avec les évolutions du site.
model Manual {
  id           String   @id @default(cuid())
  audience     String   // "user" | "admin" | "superadmin"
  version      String   // ex "2026.05.06.1" (date + ordre)
  htmlContent  String   @db.Text
  markdownContent String? @db.Text  // version markdown pour script vidéo
  pdfUrl       String?  // URL MinIO du PDF rendu (optionnel)
  videoScript  String?  @db.Text  // script narration vidéo + timecodes screenshots
  sectionCount Int      @default(0)
  wordCount    Int      @default(0)
  publishedAt  DateTime?
  publishedToTelegram Boolean @default(false)
  generatedBy  String   @default("gemini")
  createdAt    DateTime @default(now())

  @@index([audience, createdAt])
  @@index([publishedAt])
}

/// Décisions de modération IA sur les posts du forum (audit trail).
model ModerationDecision {
  id         String   @id @default(cuid())
  targetType String   // forum_post | forum_thread | testimony | photo
  targetId   String
  score      Float    // 0..1, plus c'est haut plus c'est toxique
  category   String?  // toxic | hate | spam | nsfw | self_harm | safe
  reason     String?  @db.Text
  action     String   // hidden | flagged | approved
  reviewedBy String?  // userId si revu manuellement
  reviewedAt DateTime?
  createdAt  DateTime @default(now())

  @@index([targetType, targetId])
  @@index([action, createdAt])
}

/// Partenaires affichés dans le bandeau home + page /partenaires
model Partner {
  id          String   @id @default(cuid())
  name        String
  url         String
  logoUrl     String?
  description String?  @db.Text
  category    String?  // ex: "Association", "Lieu de culte", "Média", "Film", "Entreprise"
  order       Int      @default(0)
  published   Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([order])
}

/// Boutique de produits dérivés (T-shirts, mugs, posters, livres…)
model Product {
  id          String   @id @default(cuid())
  slug        String   @unique
  title       String
  description String?  @db.Text
  priceCents  Int      // prix de base en centimes (ex: 2500 = 25.00 €) — override possible par variant
  currency    String   @default("EUR")
  images      String[] // URLs (cover + galerie produit principal)
  stock       Int?     // null = stock illimité — si productVariants[], la somme des stocks de variants prime
  category    String?
  variants    Json?    // legacy : options simples { Taille:[…], Couleur:[…] }
  order       Int      @default(0)
  published   Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Dropshipping print-on-demand
  dropProvider     String?  // 'gelato' | 'tpop' | 'printful' | null
  dropProductId    String?  // ID du produit chez le fournisseur (sync depuis catalogue)
  dropVariantMap   Json?    // map { variantId interne: variantId fournisseur }
  costCents        Int?     // Prix d'achat unitaire HT (chez le fournisseur)

  orderItems       OrderItem[]
  productVariants  ProductVariant[]
  // V2.1
  reviews          ProductReview[]
  wishlist         Wishlist[]

  @@index([published, order])
}

/// Variants détaillés : prix, stock et images par combinaison (Taille M Rose, Taille L Noir, etc.)
model ProductVariant {
  id            String   @id @default(cuid())
  productId     String
  product       Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  name          String   // ex: "T-shirt M Rose pastel"
  sku           String?  // référence interne (optionnel)
  options       Json     // ex: { "Taille": "M", "Couleur": "Rose pastel" }
  priceCents    Int?     // null = utilise le prix de base du produit
  stock         Int?     // null = stock illimité
  images        String[] // images spécifiques à ce variant (sinon fallback images produit)
  order         Int      @default(0)
  published     Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([productId, order])
}

enum OrderStatus {
  PENDING
  PAID
  SHIPPED
  CANCELLED
  REFUNDED
}

enum PaymentProvider {
  STRIPE
  SQUARE
  HELLOASSO
  MANUAL
}

model Order {
  id              String          @id @default(cuid())
  email           String
  name            String?
  phone           String?
  shippingAddress String?         @db.Text
  shippingCity    String?
  shippingZip     String?
  shippingCountry String?         @default("FR")
  totalCents      Int
  currency        String          @default("EUR")
  status          OrderStatus     @default(PENDING)
  paymentProvider PaymentProvider?
  paymentId       String?         // ID externe (Stripe session, Square checkout)
  notes           String?         @db.Text

  // Suivi expédition
  weightGrams     Int?            // Poids total du colis en grammes
  carrier         String?         // "colissimo", "mondial-relay", "chronopost", etc.
  shippingCost    Int?            // En centimes
  trackingNumber  String?
  trackingUrl     String?
  shippedAt       DateTime?
  deliveredAt     DateTime?

  // Token public pour suivi (URL /commande/{token})
  publicToken     String          @unique @default(cuid())

  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  items           OrderItem[]

  @@index([status, createdAt])
  @@index([publicToken])
}

model OrderItem {
  id         String  @id @default(cuid())
  orderId    String
  order      Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productId  String
  product    Product @relation(fields: [productId], references: [id])
  quantity   Int
  priceCents Int     // snapshot du prix au moment de la commande
  variant    Json?   // ex: { "size": "M", "color": "Rose" }
}

/// Tracking simple des pages vues (analytics interne, RGPD-friendly : pas d'IP, juste un hash anonyme)
model PageView {
  id          String   @id @default(cuid())
  path        String
  visitorHash String   // hash anonyme (IP+UA+date) — un visiteur unique par jour
  referrer    String?
  country     String?
  createdAt   DateTime @default(now())

  @@index([path, createdAt])
  @@index([createdAt])
  @@unique([path, visitorHash, createdAt])
}

/// Commentaires sur les photos (modération avant publication)
model PhotoComment {
  id          String   @id @default(cuid())
  photoId     String
  authorName  String   // nom affiché (peut être pseudo)
  authorEmail String?  // pour modération éventuelle
  content     String   @db.Text
  approved    Boolean  @default(true)  // mode auto-approve, peut passer en false pour modération
  createdAt   DateTime @default(now())

  @@index([photoId, createdAt])
}

model AuditLog {
  id         String   @id @default(cuid())
  userId     String?
  user       User?    @relation(fields: [userId], references: [id])
  action     String
  target     String?
  metadata   Json?
  createdAt  DateTime @default(now())

  @@index([createdAt])
}

/// Log de TOUS les emails envoyés via sendEmail (Resend ou SMTP)
/// Permet de diagnostiquer pourquoi un email n'arrive pas chez le destinataire.
model EmailLog {
  id           String   @id @default(cuid())
  to           String                              // destinataire
  fromAddr     String                              // adresse expéditeur utilisée
  subject      String
  type         String   @default("transactional")  // transactional | newsletter | confirmation | test | admin-notify
  provider     String   @default("resend")         // resend | smtp
  status       String   @default("pending")        // pending | sent | failed
  providerId   String?                             // message-id renvoyé par Resend
  errorMessage String?  @db.Text                   // message d'erreur si échec
  campaignId   String?                             // si lié à une campagne newsletter
  createdAt    DateTime @default(now())

  @@index([createdAt])
  @@index([to, createdAt])
  @@index([type, status, createdAt])
}

/// RAG « Demandez à GLD » — bibliothèque de connaissances thématiques
model KnowledgeDoc {
  id          String           @id @default(cuid())
  title       String
  source      String?          // URL d'origine, nom de fichier PDF, "manuel"
  sourceType  String           @default("text") // text | pdf | url | photo
  author      String?          // Auteur original / référence
  content     String           @db.Text         // Texte complet (avant chunking)
  tags        String[]         @default([])     // ex ["chrétien", "lgbtq", "sermon"]
  locale      String           @default("fr")
  enabled     Boolean          @default(true)
  chunks      KnowledgeChunk[]
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  @@index([enabled, locale])
}

/// Chunk indexé d'un document, avec son embedding sérialisé
model KnowledgeChunk {
  id         String       @id @default(cuid())
  docId      String
  doc        KnowledgeDoc @relation(fields: [docId], references: [id], onDelete: Cascade)
  position   Int          // Ordre dans le document
  text       String       @db.Text
  /// Embedding stocké comme tableau JSON de floats (768 dim Gemini text-embedding-004)
  /// Recherche cosinus en JS — suffisant jusqu'à ~10k chunks
  embedding  Json
  tokens     Int          @default(0)
  createdAt  DateTime     @default(now())

  @@index([docId])
}

/// Question posée au chat à laquelle le RAG n'a pas su répondre
/// → file d'attente que l'admin peut traiter pour enrichir la base
model UnansweredQuery {
  id          String   @id @default(cuid())
  question    String   @db.Text
  locale      String   @default("fr")
  topScore    Float    @default(0)        // Meilleure similarité trouvée
  status      String   @default("PENDING") // PENDING | ANSWERED | DISCARDED
  adminAnswer String?  @db.Text            // Si l'admin a répondu, ajouté à la base
  createdAt   DateTime @default(now())

  @@index([status, createdAt])
}

// ───────────────────────────────────────────────
// V5 — GLD CONNECT (réseau social 3-en-1)
// ───────────────────────────────────────────────

/// Profil unique avec toggles de visibilité par mode.
model ConnectProfile {
  id           String   @id @default(cuid())
  userId       String   @unique
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  handle       String   @unique  // ex: "marc-antoine" pour /connect/profil/marc-antoine
  displayName  String
  birthYear    Int?     // pour vérification 18+ (mode Rencontres)
  city         String?
  country      String?  @default("FR")
  bio          String?  @db.Text
  photos       String[] @default([])  // jusqu'à 6 URLs
  verified     Boolean  @default(false)
  verifiedAt   DateTime?

  // Visibilité par mode (l'user choisit)
  showInMur        Boolean  @default(true)
  showInRencontres Boolean  @default(false)
  showInPro        Boolean  @default(false)

  // Mode Rencontres
  intentions       String[] @default([])  // ["amour","amitie_spi","mentor","coloc"]
  quote            String?  @db.Text       // citation/verset perso
  maxDistanceKm    Int      @default(50)
  ageRangeMin      Int      @default(18)
  ageRangeMax      Int      @default(99)
  showOnlyVerified Boolean  @default(true)

  // Mode Pro
  jobTitle         String?
  proCategory      String?  // pasteur|therapeute|avocat|coach|photographe|lieu|autre
  proPitch         String?  @db.Text
  proAvailable     Boolean  @default(false)
  proRate          String?  // ex: "à partir de 60€" (free-form pour sliding scale)

  // Identité partagée mais affichage par contexte
  identity         String?
  traditions       String[] @default([])

  // Geo
  lat              Float?
  lng              Float?

  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@index([showInRencontres, country])
  @@index([showInPro, proCategory])
}

/// Swipe (like / pass / super) — base pour détecter les matches.
model ConnectSwipe {
  id        String   @id @default(cuid())
  fromId    String
  toId      String
  from      User     @relation("swipeFrom", fields: [fromId], references: [id], onDelete: Cascade)
  to        User     @relation("swipeTo",   fields: [toId],   references: [id], onDelete: Cascade)
  action    String   // "like" | "pass" | "super"
  intentions String[] @default([])  // intentions ciblées (subset de celles du swiper)
  createdAt DateTime @default(now())

  @@unique([fromId, toId])
  @@index([toId, action])
}

/// Match = 2 swipes "like"/"super" croisés. Détecté côté API au moment du swipe.
model ConnectMatch {
  id           String   @id @default(cuid())
  user1Id      String
  user2Id      String
  intentions   String[] @default([])  // intentions communes
  status       String   @default("active") // active | unmatched | reported
  createdAt    DateTime @default(now())

  @@unique([user1Id, user2Id])
  @@index([user1Id])
  @@index([user2Id])
}

/// Connexion Pro (LinkedIn-like) — request + accept.
model ConnectConnection {
  id        String   @id @default(cuid())
  fromId    String
  toId      String
  from      User     @relation("connFrom", fields: [fromId], references: [id], onDelete: Cascade)
  to        User     @relation("connTo",   fields: [toId],   references: [id], onDelete: Cascade)
  status    String   @default("pending") // pending | accepted | declined
  message   String?  @db.Text             // mot d'introduction
  createdAt DateTime @default(now())
  acceptedAt DateTime?

  @@unique([fromId, toId])
  @@index([toId, status])
}

/// Post sur le mur Communauté.
model ConnectPost {
  id          String   @id @default(cuid())
  authorId    String
  author      User     @relation(fields: [authorId], references: [id], onDelete: Cascade)
  type        String   @default("post") // post | temoignage | priere | photo | event
  text        String   @db.Text
  imageUrl    String?
  videoUrl    String?
  circleSlug  String?  // ex: "ramadan-inclusif"
  visibility  String   @default("public") // public | friends | circle | private
  // Modération auto IA Gemini
  moderationStatus String  @default("pending") // pending | approved | flagged | removed
  moderationNotes  String? @db.Text

  reactions   ConnectReaction[]
  commentsCount Int @default(0)

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([authorId, createdAt])
  @@index([visibility, moderationStatus, createdAt])
}

/// Réaction (♥ like / 🕊 prière / ⭐ super).
model ConnectReaction {
  id        String   @id @default(cuid())
  postId    String
  post      ConnectPost @relation(fields: [postId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  type      String   // "like" | "pray" | "amen" | "super"
  createdAt DateTime @default(now())

  @@unique([postId, userId, type])
  @@index([postId])
}

/// Conversation entre 2 users (toutes modes confondus, taggée).
model ConnectConversation {
  id        String   @id @default(cuid())
  user1Id   String
  user2Id   String
  user1     User     @relation("convA", fields: [user1Id], references: [id], onDelete: Cascade)
  user2     User     @relation("convB", fields: [user2Id], references: [id], onDelete: Cascade)
  origin    String   @default("connect") // match | connection | post | direct
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  messages  ConnectMessage[]

  @@unique([user1Id, user2Id])
  @@index([user1Id])
  @@index([user2Id])
}

/// Message dans une conversation.
model ConnectMessage {
  id             String   @id @default(cuid())
  conversationId String
  conversation   ConnectConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  senderId       String
  sender         User     @relation(fields: [senderId], references: [id], onDelete: Cascade)
  text           String   @db.Text
  imageUrl       String?
  audioUrl       String?
  readAt         DateTime?
  // Modération auto
  moderationStatus String  @default("approved") // approved | flagged | removed
  createdAt      DateTime @default(now())

  @@index([conversationId, createdAt])
}

/// Signalement utilisateur ou contenu.
model ConnectReport {
  id          String   @id @default(cuid())
  reporterId  String
  reporter    User     @relation("reporterRel", fields: [reporterId], references: [id], onDelete: Cascade)
  reportedId  String
  reported    User     @relation("reportedRel", fields: [reportedId], references: [id], onDelete: Cascade)
  contentType String?  // "post" | "message" | "profile" — null si signalement profil pur
  contentId   String?
  reason      String   // "harassment" | "hate" | "fake" | "spam" | "explicit" | "other"
  details     String?  @db.Text
  status      String   @default("pending") // pending | reviewed | actioned | dismissed
  adminNotes  String?  @db.Text
  createdAt   DateTime @default(now())
  reviewedAt  DateTime?

  @@index([status, createdAt])
}

/// Block entre users (mutuel, supprime tout contact).
model ConnectBlock {
  id        String   @id @default(cuid())
  blockerId String
  blocker   User     @relation("blockerRel", fields: [blockerId], references: [id], onDelete: Cascade)
  blockedId String
  blocked   User     @relation("blockedRel", fields: [blockedId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([blockerId, blockedId])
}

/// Abonnement Premium (Stripe).
model ConnectPremium {
  id                 String   @id @default(cuid())
  userId             String   @unique
  user               User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  stripeCustomerId   String?
  stripeSubId        String?
  status             String   @default("none") // none | trialing | active | past_due | canceled
  trialEndsAt        DateTime?
  currentPeriodEnd   DateTime?
  cancelAtPeriodEnd  Boolean  @default(false)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
}
