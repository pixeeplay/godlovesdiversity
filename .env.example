# ──────────────────────────────────────────────────────────
#  parislgbt.com / francelgbt.com — .env.example
#  Copy to .env  ➜  cp .env.example .env
# ──────────────────────────────────────────────────────────

# ─── Database ───
DATABASE_URL=postgresql://lgbt:lgbt@postgres:5432/parislgbt?schema=public

# ─── Redis ───
REDIS_URL=redis://redis:6379

# ─── Auth (NextAuth) ───
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=change-me-with-openssl-rand-base64-32
ADMIN_EMAIL=arnaud@gredai.com
ADMIN_PASSWORD=change-me-after-first-login

# ─── Multi-domaines ───
SITE_PRIMARY_DOMAIN=lgbt.pixeeplay.com
SITE_SCOPE_PARIS_DOMAIN=parislgbt.com
SITE_SCOPE_FRANCE_DOMAIN=francelgbt.com

# ─── Storage (MinIO / S3) ───
S3_ENDPOINT=http://minio:9000
S3_PUBLIC_ENDPOINT=http://localhost:9000
S3_REGION=us-east-1
S3_BUCKET=parislgbt
S3_ACCESS_KEY=lgbtminio
S3_SECRET_KEY=change-me-in-prod

# ─── Gemini AI ───
GEMINI_API_KEY=
GEMINI_TEXT_MODEL=gemini-2.5-pro
GEMINI_IMAGE_MODEL=imagen-3.0-generate-002

# ─── Email (Resend) ───
RESEND_API_KEY=
EMAIL_FROM="parislgbt <hello@parislgbt.com>"
SMTP_HOST=mailpit
SMTP_PORT=1025

# ─── Maps ───
NEXT_PUBLIC_MAPBOX_TOKEN=

# ─── Réseaux sociaux ───
META_APP_ID=
META_APP_SECRET=
META_PAGE_ACCESS_TOKEN=
INSTAGRAM_BUSINESS_ID=

X_API_KEY=
X_API_SECRET=
X_ACCESS_TOKEN=
X_ACCESS_TOKEN_SECRET=

LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=

TIKTOK_CLIENT_KEY=
TIKTOK_CLIENT_SECRET=

# ─── Stripe (Premium Connect + Boutique) ───
STRIPE_SECRET_KEY=
STRIPE_PUBLIC_KEY=
STRIPE_WEBHOOK_SECRET=

# ─── Telegram bot ───
TELEGRAM_BOT_TOKEN=
TELEGRAM_WEBHOOK_SECRET=

# ─── HeyGen / ElevenLabs ───
HEYGEN_API_KEY=
ELEVENLABS_API_KEY=

# ─── Sendcloud (boutique shipping) ───
SENDCLOUD_PUBLIC_KEY=
SENDCLOUD_SECRET_KEY=

# ─── App ───
NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_DEFAULT_LOCALE=fr
NEXT_PUBLIC_SUPPORTED_LOCALES=fr,en
