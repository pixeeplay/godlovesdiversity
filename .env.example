# ──────────────────────────────────────────────────────────
#  GOD LOVES DIVERSITY — .env.example
#  Copy to .env  ➜  cp .env.example .env
# ──────────────────────────────────────────────────────────

# ─── Database ───
DATABASE_URL=postgresql://gld:gld@postgres:5432/godlovesdiversity?schema=public

# ─── Redis ───
REDIS_URL=redis://redis:6379

# ─── Auth (NextAuth) ───
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=change-me-with-openssl-rand-base64-32
ADMIN_EMAIL=arnaud@gredai.com
ADMIN_PASSWORD=GodLoves2026!

# ─── Storage (MinIO / S3) ───
S3_ENDPOINT=http://minio:9000
S3_PUBLIC_ENDPOINT=http://localhost:9000
S3_REGION=us-east-1
S3_BUCKET=godlovesdiversity
S3_ACCESS_KEY=gldminio
S3_SECRET_KEY=gldminio-secret

# ─── Gemini AI (à remplir plus tard) ───
GEMINI_API_KEY=
GEMINI_TEXT_MODEL=gemini-2.5-pro
GEMINI_IMAGE_MODEL=imagen-3.0-generate-002

# ─── Jina Reader (scraping RAG, optionnel) ───
# Sans clé : ~20 req/min gratuites. Avec clé : rate limit beaucoup plus large.
# https://jina.ai/reader → Get API key
JINA_API_KEY=

# ─── Email (Resend) ───
RESEND_API_KEY=
EMAIL_FROM="God Loves Diversity <hello@godlovesdiversity.com>"

# ─── Maps ───
NEXT_PUBLIC_MAPBOX_TOKEN=

# ─── Réseaux sociaux (à remplir plus tard) ───
META_APP_ID=
META_APP_SECRET=
META_PAGE_ACCESS_TOKEN=
INSTAGRAM_BUSINESS_ID=

X_API_KEY=
X_API_SECRET=
X_ACCESS_TOKEN=
X_ACCESS_TOKEN_SECRET=

LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=

TIKTOK_CLIENT_KEY=
TIKTOK_CLIENT_SECRET=

# ─── App ───
NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_DEFAULT_LOCALE=fr

# ─── Crons sécurisés (Coolify scheduled tasks) ───
# Header X-Cron-Secret de chaque cron HTTP. Si vide → endpoints crons OUVERTS (dev only).
CRON_SECRET=

# ─── PriceWatch — comparateur prix ───
# Email destinataire des alertes (sinon settings.prices.alertEmail, sinon ADMIN_EMAIL)
PRICE_ALERT_EMAIL=
# Webhook Slack pour push alertes (incoming webhook URL)
PRICE_ALERT_SLACK_WEBHOOK=

# ─── PriceWatch — ingestion tarifs fournisseurs (Phase 2) ───
# Secret du webhook Resend pour parser les mails entrants avec PJ tarif
TARIFF_MAIL_SECRET=

# ─── PriceWatch — PIM productsmanager.app (Phase 3) ───
PM_API_URL=
PM_API_KEY=

# ─── Assistant juridique paperasse (override repo/branche) ───
# Par défaut : romainsimon/paperasse @ master
PAPERASSE_REPO=
PAPERASSE_BRANCH=

# ─── Claude CLI online (/admin/claude-cli) ───
# Au choix (un des deux) :
ANTHROPIC_API_KEY=
# OU OAuth abo Max (récupère depuis ~/.claude/credentials.json sur ton Mac après `claude-code login`)
CLAUDE_CODE_OAUTH_TOKEN=

# ─── VS Code online (/admin/vscode-online) ───
GITHUB_REPO_FULL_NAME=pixeeplay/godlovesdiversity
GITHUB_DEFAULT_BRANCH=main
# Optional : code-server self-hosted via Tailscale (ex: http://100.x.x.x:8443)
CODE_SERVER_URL=
