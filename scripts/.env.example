# ──────────────────────────────────────────────────────────
#  parislgbt-scraper — .env.example
#  Copy to .env  ➜  cp .env.example .env
# ──────────────────────────────────────────────────────────

# Clé API Gemini (gratuite — https://aistudio.google.com/apikey)
# Tier gratuit : 15 req/min, 1500 req/jour — largement suffisant pour 440 URLs.
GEMINI_API_KEY=AIzaSy...your-key-here

# Modèle Gemini à utiliser (3.1 Flash Lite = rapide + très peu cher)
GEMINI_MODEL=gemini-2.5-flash-lite-preview-09-2025

# Concurrence (req simultanées vers Jina + Gemini)
SCRAPER_CONCURRENCY=4

# Délai entre 2 batches (ms) — pour respecter les rate limits
SCRAPER_DELAY_MS=500

# Chemin de sortie pour les JSON scrapés
OUTPUT_DIR=./output

# Optionnel : ré-enrichissement géoloc via Nominatim OSM (gratuit, max 1 req/s)
NOMINATIM_USER_AGENT=parislgbt-scraper/1.0 (contact@parislgbt.com)
